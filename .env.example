# P2-04 security baseline example.
# Production must override every value below. Do not copy these placeholders as real secrets.

# JWT / auth
JWT_SECRET=replace-with-strong-random-secret-at-least-32-bytes
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-initial-admin-password

# Database credentials
AUTH_DB_PASSWORD=replace-with-auth-db-password
PARTNER_DB_PASSWORD=replace-with-partner-db-password
PIPELINE_DB_PASSWORD=replace-with-pipeline-db-password
QUALITY_DB_PASSWORD=replace-with-quality-db-password
BILLING_DB_PASSWORD=replace-with-billing-db-password
MYSQL_ROOT_PASSWORD=replace-with-mysql-root-password

# SM4 keys for encrypted credentials and stored data
PARTNER_CREDENTIAL_KEY=replace-with-16-byte-sm4-key
API_CREDENTIAL_SM4_KEY=replace-with-16-byte-sm4-key
DATA_ASSET_SM4_KEY=replace-with-16-byte-sm4-key

# Object storage
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key

# Messaging and gateway limits
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
SENTINEL_DEFAULT_QPS=500

# Security scanning
NVD_API_KEY=optional-nvd-api-key-for-dependency-check
ZAP_TARGET_URL=https://replace-with-deployed-test-url
ZAP_AUTH_TOKEN=replace-with-test-bearer-token
